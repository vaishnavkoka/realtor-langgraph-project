# Real Estate Search Engine - Environment Configuration
# Copy this file to .env and add your actual API keys

# Free API Keys (Get these for full functionality)
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_token_here
SERPER_API_KEY=your_serper_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./realestate.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/realestate_db

# Redis Configuration (for memory/session management)
REDIS_URL=redis://localhost:6379

# Vector Store Configuration
FAISS_INDEX_PATH=data/faiss_index

# Logging Level
LOG_LEVEL=INFO

# Development Settings
DEBUG=true
ENVIRONMENT=development

# API Rate Limiting (optional overrides)
GROQ_DAILY_LIMIT=25000
SERPER_MONTHLY_LIMIT=2400
TAVILY_MONTHLY_LIMIT=950

# Instructions:
# 1. Sign up for free accounts and get API keys:
#    - Groq: https://console.groq.com/keys
#    - Serper: https://serper.dev/
#    - Tavily: https://tavily.com/
#    - HuggingFace: https://huggingface.co/settings/tokens
#    - Cohere: https://dashboard.cohere.ai/
#
# 2. Replace the placeholder values above with your actual keys
#
# 3. Rename this file to .env
#
# 4. Make sure .env is in your .gitignore file (it already is)